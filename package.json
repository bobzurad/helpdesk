{
  "name": "helpdesk",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["client", "server", "e2e"],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter @helpdesk/client --filter @helpdesk/server build",
    "typecheck": "bun --filter '*' typecheck",
    "test:e2e": "bun --filter @helpdesk/e2e test",
    "test:e2e:ui": "bun --filter @helpdesk/e2e test:ui",
    "test:e2e:install": "bun --filter @helpdesk/e2e install-browsers"
  }
}
