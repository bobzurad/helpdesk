{
  "name": "@helpdesk/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --env-file=../.env --hot src/index.ts",
    "start": "bun --env-file=../.env src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "create-user": "bun --env-file=../.env scripts/create-user.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.9",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^5.6.0"
  }
}
