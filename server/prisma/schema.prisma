// Prisma schema for the helpdesk app.
// Datasource URL is configured in prisma.config.ts (Prisma 7+).

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

enum UserRole {
  ADMIN
  AGENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(AGENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
