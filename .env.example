# Postgresql Environment Variables
POSTGRES_DB=helpdesk
POSTGRES_USER=root
POSTGRES_PASSWORD=password1!
# pgAdmin Environment Variables
PGADMIN_DEFAULT_EMAIL=foo@bar.com # Dummy email but correctly form
PGADMIN_DEFAULT_PASSWORD=password1!
PGADMIN_LISTEN_ADDRESS=[::] # Default value
PPGADMIN_LISTEN_PORT=80 # Default value when TLS disabled

# Application Database (used by Prisma)
DATABASE_URL=postgresql://root:password1!@localhost:5432/helpdesk

# Test database (used by Playwright e2e — must contain "test" in the name).
# The e2e workspace resets this DB before each test run.
TEST_DATABASE_URL=postgresql://root:password1!@localhost:5432/helpdesk_test

# Test admin credentials (seeded into the test DB on every reset).
# Must satisfy the seed's password validation (>=12 chars, not starting with "password" / "change_me").
TEST_SEED_ADMIN_EMAIL=admin@test.local
TEST_SEED_ADMIN_PASSWORD=test-admin-password-12345

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:5173"

# CORS allowlist for the Express API (comma-separated origins)
CORS_ORIGINS="http://localhost:5173"

# Database seed (used by `prisma db seed`)
# Set to a strong password before running the seed — the seed script will
# refuse weak/placeholder values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEEDING